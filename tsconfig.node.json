{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"],
    "outDir": "./node_modules/.tmp/tsconfig.node",
    "emitDeclarationOnly": false,
    "declaration": true
  },
  "include": ["vite.config.ts"]
}
